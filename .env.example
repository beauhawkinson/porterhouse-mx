# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/jp_motorcross

# ── Auth (better-auth) ────────────────────────────────────────────────────────
BETTER_AUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=your-super-secret-key-at-least-32-chars

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Get from https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Admin ─────────────────────────────────────────────────────────────────────
# Comma-separated list of Google emails allowed to access /admin
ADMIN_EMAILS="owner@example.com,admin@example.com"

# ── Stripe ────────────────────────────────────────────────────────────────────
# Get from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Get from https://dashboard.stripe.com/test/webhooks (or from `stripe listen` output)
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Cloudflare R2 (product image storage) ─────────────────────────────────────
# Cloudflare account ID (dashboard → R2 → Account details)
R2_ACCOUNT_ID=your-account-id
# R2 API token credentials (R2 → Manage API Tokens → Create API Token)
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
# The bucket name (e.g. porterhouse-mx). Images are stored under product-images/
R2_BUCKET_NAME=porterhouse-mx
# Public bucket URL — the r2.dev URL or your custom domain, no trailing slash
R2_PUBLIC_URL=https://pub-xxxxxxxx.r2.dev
