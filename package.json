{
  "name": "porterhouse-mx",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --bun vite dev --port 3000",
    "build": "bun run --bun vite build",
    "start": "bun run --bun vite preview",
    "knip": "knip-bun",
    "prepare": "lefthook install",
    "db:generate": "bun run --env-file .env.local drizzle-kit generate",
    "db:migrate": "bun run --env-file .env.local drizzle-kit migrate",
    "db:studio": "bun run --env-file .env.local drizzle-kit studio",
    "db:push": "bun run --env-file .env.local drizzle-kit push",
    "db:seed": "bun run src/lib/db/seed.ts"
  },
  "dependencies": {
    "@better-auth/stripe": "^1.2.7",
    "@t3-oss/env-core": "^0.12.0",
    "@tanstack/react-router": "^1.168.22",
    "@tanstack/react-start": "^1.167.41",
    "better-auth": "^1.2.7",
    "class-variance-authority": "^0.7.1",
    "drizzle-orm": "^0.43.1",
    "knip": "^6.12.1",
    "lucide-react": "^1.14.0",
    "nitro": "^3.0.260429-beta",
    "postgres": "^3.4.7",
    "radix-ui": "^1.4.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "stripe": "^17.7.0",
    "tailwindcss": "^4.2.4",
    "ts-pattern": "^5.9.0",
    "zod": "^4",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@tailwindcss/vite": "^4.1.6",
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.3",
    "@types/react-dom": "^19.1.3",
    "@vitejs/plugin-react": "^6.0.1",
    "drizzle-kit": "^0.31.1",
    "lefthook": "^2.1.6",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.8.3",
    "vite": "^8.0.11"
  }
}
